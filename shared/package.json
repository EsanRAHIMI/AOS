{
  "name": "@factory/shared",
  "version": "0.1.0",
  "description": "Shared contracts, schemas, types, constants and reusable build-time utilities for all Autonomous OS Kernel services. NOT a runtime dependency between deployed containers — services communicate over HTTP using these contracts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "mongodb": "^6.12.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/node": "^22.15.0",
    "vitest": "^4.1.10"
  }
}
