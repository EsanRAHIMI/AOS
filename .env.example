# =====================================================================
# Autonomous OS Kernel — SHARED environment template
# Copy per service into <service>/.env (never commit real .env files).
# Service-specific overrides live in deployment/env/<service>.env.example
# =====================================================================

# --- Runtime ---
NODE_ENV=development

# --- Factory identity ---
FACTORY_ENV=local                       # local | staging | production
FACTORY_PUBLIC_URL=http://localhost:4100 # dashboard public URL
FACTORY_API_URL=http://localhost:4101    # gateway-api URL
FACTORY_INTERNAL_TOKEN=                  # shared secret for service-to-service auth
FACTORY_ADMIN_TOKEN=                     # human/admin privileged token (dashboard/gateway)

# --- Database (MongoDB Atlas is the required primary datastore) ---
MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

# --- Object storage (AWS S3 is the required object store) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=

# --- LLM providers (router abstraction selects provider at runtime) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic           # anthropic | openai

# --- Web search — REQUIRED on internet-research-service for real search;
# --- optional elsewhere. Optional, falls back to LLM-recall/curated
# --- knowledge when unset, clearly marked via sourceMode. Phase AG.1: this
# --- key is read once at process boot (services/internet-research-service/
# --- src/index.ts) — after setting or changing it, RESTART
# --- internet-research-service (not just gateway-api) or it keeps running
# --- with the old value. Setting it on gateway-api too is optional and only
# --- affects the cosmetic GET /v1/system/integrations status display, not
# --- whether search actually runs (gateway-api always delegates the real
# --- call to internet-research-service). ---
TAVILY_API_KEY=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_DEFAULT_BRANCH=main

# --- Dokploy (deployment host) ---
DOKPLOY_BASE_URL=
DOKPLOY_API_TOKEN=

# --- Per-service identity (override in each service .env) ---
SERVICE_ID=
SERVICE_NAME=
SERVICE_DOMAIN=
SERVICE_PORT=

# --- Service registry / discovery ---
SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

# --- Observability ---
LOG_LEVEL=info                           # trace | debug | info | warn | error | fatal

# --- Dashboard login (synced into dashboard-web/.env) ---
# Leave all three empty for local demo logins (owner@local / owner).
# DASHBOARD_SESSION_SECRET=                 # random string ≥32 chars (prod required)
# DASHBOARD_ADMIN_EMAIL=
# DASHBOARD_ADMIN_PASSWORD_HASH=            # scrypt$... from: node scripts/hash-password.mjs 'pw'
# DASHBOARD_ADMIN_PASSWORD=                 # dev-only plaintext (ignored when hash is set)

CODE_WORKSPACE_ROOT="/Users/ehsanrahimi/Desktop/AOS/Agentic Operating System/autonomous-os-kernel"