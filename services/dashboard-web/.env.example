NODE_ENV=development

SERVICE_ID=dashboard-web
SERVICE_NAME=Dashboard Web
SERVICE_PORT=4100

# Gateway the dashboard calls server-side. Admin token authenticates the human.
FACTORY_API_URL=http://localhost:4101
FACTORY_ADMIN_TOKEN=change-me-admin

# Event bus for the live SSE proxy (server-side only).
EVENT_BUS_URL=http://localhost:4111
FACTORY_INTERNAL_TOKEN=change-me-internal

# --- Phase 12: dashboard authentication ---
# Secret used to sign session cookies (HMAC). Use a long random value in prod.
DASHBOARD_SESSION_SECRET=change-me-session-secret-min-32-chars

# Owner login. Prefer a scrypt hash (scrypt$<saltHex>$<hashHex>); generate with:
#   node scripts/hash-password.mjs 'your-password'
DASHBOARD_ADMIN_EMAIL=owner@simorx.com
DASHBOARD_ADMIN_PASSWORD_HASH=
# Dev-only plaintext fallback (ignored if a hash is set). Do NOT use in production.
DASHBOARD_ADMIN_PASSWORD=

# Optional operator + viewer logins (same hash/plain rules). Used for RBAC demos.
DASHBOARD_OPERATOR_EMAIL=
DASHBOARD_OPERATOR_PASSWORD_HASH=
DASHBOARD_OPERATOR_PASSWORD=
DASHBOARD_VIEWER_EMAIL=
DASHBOARD_VIEWER_PASSWORD_HASH=
DASHBOARD_VIEWER_PASSWORD=

# In local dev, if NO dashboard users are configured above, three demo logins are
# seeded automatically: owner@local / owner, operator@local / operator,
# viewer@local / viewer. These are disabled when NODE_ENV=production.
