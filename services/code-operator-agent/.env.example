NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=code-operator-agent
SERVICE_NAME=Code Operator Agent
SERVICE_DOMAIN=https://code.simorx.com
SERVICE_PORT=4122

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

# Phase X — code workspace (REQUIRED for code tools; without it every code tool
# reports not_configured cleanly). Point at a git checkout of the monorepo that
# this agent may modify on isolated branches. NEVER point at a live production
# deployment directory.
CODE_WORKSPACE_ROOT="/Users/ehsanrahimi/Desktop/AOS/Agentic Operating System/autonomous-os-kernel"

# Git / GitHub (optional — needed for commit/push/PR tools)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=autonomous-os-kernel
GITHUB_DEFAULT_BRANCH=main

# Phase Y — Autonomous Staging Workspace limits (powerful but bounded).
WORKSPACE_MAX_ITERATIONS=10
WORKSPACE_MAX_MINUTES=45
WORKSPACE_MAX_FILES_CHANGED=80
WORKSPACE_REQUIRE_APPROVAL_BEFORE_MIGRATION=true
WORKSPACE_ALLOW_AUTOFIX=true
WORKSPACE_ALLOW_NEW_SERVICE=true
WORKSPACE_ALLOW_EXISTING_SERVICE_EVOLUTION=true

LOG_LEVEL=info
