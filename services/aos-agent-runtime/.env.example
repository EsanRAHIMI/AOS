# K1 Consolidation Prep (D-168/D-172) — see services/aos-agent-runtime/README.md.
#
# SERVICE_ID/SERVICE_PORT below describe THIS PROCESS's own identity for its
# own structured logs only — they are NOT the port any HTTP client connects
# to, and are deliberately never passed into any of the 7 workers this
# process hosts. Each worker binds its own historical port instead:
#   architect-agent -> 4103   reviewer-agent          -> 4106
#   qa-agent        -> 4107   memory-agent             -> 4109
#   documentation-service -> 4110   report-agent       -> 4114
#   internet-research-service -> 4115
# SERVICE_PORT here is a placeholder; nothing listens on it.
NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=aos-agent-runtime
SERVICE_NAME=AOS Agent Runtime
SERVICE_DOMAIN=
SERVICE_PORT=4199

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic

# Optional (Batch 2A, D-172) — internet-research-service worker only. Unset
# means read-only web search is off and research degrades honestly to
# LLM-recall/curated fallback (sourceMode != 'search_api'), same as the
# original standalone service.
TAVILY_API_KEY=

LOG_LEVEL=info
