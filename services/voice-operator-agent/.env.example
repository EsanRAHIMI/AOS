NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=voice-operator-agent
SERVICE_NAME=Voice Operator Agent
SERVICE_DOMAIN=https://voice.simorx.com
SERVICE_PORT=4121

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

# LLM (optional) — explanation reasoning; deterministic router fallback otherwise.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic

# Phase 18 — realtime voice (optional). Without these, the dock runs text + browser
# voice only and clearly shows "voice provider not configured". No key ever reaches
# the browser except a short-lived ephemeral client secret minted server-side.
VOICE_PROVIDER=openai
VOICE_MODEL=gpt-4o-realtime-preview
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_SESSION_SECRET=change-me-voice-session
VOICE_MAX_SESSION_MINUTES=30
VOICE_REQUIRE_PUSH_TO_TALK=true

LOG_LEVEL=info
