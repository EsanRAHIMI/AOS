{
  "name": "@factory/file-asset-service",
  "version": "0.1.0",
  "description": "File and media storage on AWS S3 with MongoDB-tracked metadata and signed URLs for all other services.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --watch --import tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@factory/shared": "workspace:*",
    "@factory/service-kit": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "tsx": "^4.19.2",
    "@types/node": "^22.15.0"
  }
}
