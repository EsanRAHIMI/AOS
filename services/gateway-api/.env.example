NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=gateway-api
SERVICE_NAME=Gateway API
SERVICE_DOMAIN=https://api.simorx.com
SERVICE_PORT=4101

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

# Phase 12 — emergency kill-switch. true => block mutation/deploy/repair/governance
# execution (read/monitor/report only). The live value is stored in system_settings
# and toggled from the dashboard; this sets the initial default.
AUTONOMY_SAFE_MODE=false

# Optional: read only to report security-check status (never required to boot).
# DASHBOARD_SESSION_SECRET=
# GITHUB_TOKEN=

# Phase 16 — real Dokploy API execution (optional). When BOTH are set, approved
# low/medium NON-core operations execute via the Dokploy API; otherwise the kernel
# falls back to exact manual steps. The token is server-side only — never sent to
# the browser. Protected core services are never auto-executed.
DOKPLOY_BASE_URL=
DOKPLOY_API_TOKEN=
DOKPLOY_PROJECT_ID=
DOKPLOY_ENVIRONMENT_ID=

# K1 Redis Backbone (D-167, optional) — cross-instance event fan-out + rate
# limiting. Unset = local/single-instance behavior, unchanged.
REDIS_URL=
REDIS_KEY_PREFIX=factory:

# K1 BullMQ Task Queue / Producer Adoption (D-173/D-174, optional). REDIS_URL
# above must also be set for any of this to take effect. AGENT_DISPATCH_MODE
# unset (http, the default) = every dispatch stays HTTP-only, byte-identical
# to before D-174. See docs/environment-variables.md for the full semantics.
AGENT_QUEUE_MAX_ATTEMPTS=3
AGENT_QUEUE_BACKOFF_MS=2000
AGENT_QUEUE_CONCURRENCY=4
AGENT_QUEUE_TIMEOUT_MS=30000
AGENT_DISPATCH_MODE=http

LOG_LEVEL=info
