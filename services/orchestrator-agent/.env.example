NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=orchestrator-agent
SERVICE_NAME=Orchestrator Agent
SERVICE_DOMAIN=https://orchestrator.simorx.com
SERVICE_PORT=4102

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic

# K1 BullMQ Task Queue / Producer Adoption (D-173/D-174, optional). Unset
# REDIS_URL = this service dispatches/consumes over HTTP only, unchanged.
# AGENT_DISPATCH_MODE (http | queue_with_http_fallback | queue_only) gates
# whether pipeline.ts's dispatches to the 7 aos-agent-runtime workers use
# BullMQ — see docs/environment-variables.md.
REDIS_URL=
AGENT_QUEUE_MAX_ATTEMPTS=3
AGENT_QUEUE_BACKOFF_MS=2000
AGENT_QUEUE_CONCURRENCY=4
AGENT_QUEUE_TIMEOUT_MS=30000
AGENT_DISPATCH_MODE=http

LOG_LEVEL=info
