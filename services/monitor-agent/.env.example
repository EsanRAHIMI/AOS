NODE_ENV=development
FACTORY_ENV=local
FACTORY_INTERNAL_TOKEN=change-me-internal
FACTORY_ADMIN_TOKEN=

SERVICE_ID=monitor-agent
SERVICE_NAME=Monitor Agent
SERVICE_DOMAIN=https://monitor.simorx.com
SERVICE_PORT=4113

SERVICE_REGISTRY_URL=http://localhost:4108
EVENT_BUS_URL=http://localhost:4111

MONGODB_URI=
MONGODB_DB_NAME=autonomous_os_kernel

# Periodic scan interval (ms). Set 0 to disable the background scan.
MONITOR_INTERVAL_MS=60000

LOG_LEVEL=info
