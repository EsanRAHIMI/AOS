# Keep Dokploy / Docker build context small and deterministic
.git
.github
.cursor
.vscode
.idea
**/.DS_Store

# Local / generated
**/node_modules
**/.next
**/dist
**/coverage
**/.turbo
**/*.tsbuildinfo
**/.env
**/.env.*
!**/.env.example

# Docs & non-runtime assets (not needed to build services)
docs
agent-transcripts
*.log
.tmp
.cache

# Keep dokploy markdown out of image; keep deployment/docker Dockerfiles
deployment/dokploy
deployment/env
!deployment/docker
!deployment/docker/**
# Tests (do not exclude source folders named like "test" under src)
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/vitest.config.*
services/*/test
services/*/tests
shared/test
packages/*/test
